#!/usr/bin/env python3
"""
CUPS Backend that always reports printers as available.

This backend fools CUPS into always advertising printers as available,
even when they're powered off. This is useful for Windows clients that
should see printers as ready even when the power management system
has turned them off.

When no arguments are provided, it reports device information.
When called with job arguments, it forwards the job to the real backend.
"""

import sys
import os
import subprocess
import syslog
import time

# CUPS backend exit codes
CUPS_BACKEND_OK = 0
CUPS_BACKEND_FAILED = 1
CUPS_BACKEND_AUTH_REQUIRED = 2
CUPS_BACKEND_HOLD = 3
CUPS_BACKEND_STOP = 4
CUPS_BACKEND_CANCEL = 5

# Original backend to forward jobs to
ORIGINAL_BACKEND = "/usr/lib/cups/backend/usb"

# USB device detection settings
USB_RESCAN_RETRIES = 3
USB_RESCAN_DELAY = 2  # seconds to wait after rescan
USB_DEVICE_CHECK_TIMEOUT = 5  # seconds timeout for device check

def log_message(message):
    """Log message to syslog"""
    syslog.syslog(f"always-available[{os.getpid()}]: {message}")

def check_usb_device_available(device_uri):
    """
    Check if the USB device is available by attempting to query it.
    Returns True if device is available, False otherwise.
    """
    try:
        # Try to call the USB backend to see if device is available
        # Use a timeout to avoid hanging
        env = os.environ.copy()
        env['DEVICE_URI'] = device_uri

        # Call backend with no arguments to check device discovery
        # Use sudo for proper USB access permissions
        result = subprocess.run(
            ["sudo", ORIGINAL_BACKEND],
            env=env,
            capture_output=True,
            text=True,
            timeout=USB_DEVICE_CHECK_TIMEOUT,
            errors='replace'  # Handle binary data in output
        )

        # If the backend returns successfully and mentions the device, it's available
        if result.returncode == 0 and device_uri.split('/')[-1].split('?')[0] in result.stdout:
            return True

        log_message(f"USB device check failed for {device_uri}: returncode={result.returncode}")
        return False

    except subprocess.TimeoutExpired:
        log_message(f"USB device check timeout for {device_uri}")
        return False
    except Exception as e:
        log_message(f"Error checking USB device {device_uri}: {e}")
        return False

def discover_usb_device_by_model(expected_model):
    """
    Dynamically discover the correct USB device URI by matching on printer model.
    This handles cases where USB devices get different device numbers on power cycles.

    Args:
        expected_model: The printer model to look for (e.g., "HP LaserJet 2100 Series")

    Returns:
        The correct USB device URI if found, None otherwise
    """
    try:
        log_message(f"Attempting dynamic discovery for model: {expected_model}")

        # Call the USB backend to get current device list
        # Use sudo for proper USB access permissions
        result = subprocess.run(
            ["sudo", ORIGINAL_BACKEND],
            capture_output=True,
            text=True,
            timeout=10,
            errors='replace'  # Handle binary data in output
        )

        if result.returncode != 0:
            log_message(f"USB backend discovery failed: {result.stderr}")
            return None

        # Parse the output to find matching devices
        lines = result.stdout.strip().split('\n')
        for line in lines:
            if line.startswith('direct usb://'):
                parts = line.split()
                if len(parts) >= 4:
                    device_uri = parts[1]
                    device_model = parts[2].strip('"')

                    # Check if this device matches our expected model
                    # Use case-insensitive matching and partial matches
                    if (expected_model.lower() in device_model.lower() or
                        device_model.lower() in expected_model.lower()):
                        log_message(f"Found matching device: {device_uri} -> {device_model}")
                        return device_uri

                    # Special handling for HP 2100TN which appears as "USB2.0-Print"
                    if "2100" in expected_model and "USB2.0-Print" in device_uri:
                        log_message(f"Found HP 2100TN device: {device_uri}")
                        return device_uri

        log_message(f"No matching USB device found for model: {expected_model}")
        return None

    except subprocess.TimeoutExpired:
        log_message("USB device discovery timeout")
        return None
    except Exception as e:
        log_message(f"Error during USB device discovery: {e}")
        return None

def rescan_usb_ports():
    """
    Trigger a rescan of USB ports to detect newly connected devices.
    """
    try:
        log_message("Triggering USB port rescan")
        # Use udevadm to trigger USB subsystem rescan
        result = subprocess.run(
            ["sudo", "udevadm", "trigger", "--subsystem-match=usb"],
            capture_output=True,
            text=True,
            timeout=10
        )

        if result.returncode == 0:
            log_message("USB port rescan completed successfully")
            # Wait a bit for devices to be recognized
            time.sleep(USB_RESCAN_DELAY)
            return True
        else:
            log_message(f"USB port rescan failed: {result.stderr}")
            return False

    except subprocess.TimeoutExpired:
        log_message("USB port rescan timeout")
        return False
    except Exception as e:
        log_message(f"Error during USB port rescan: {e}")
        return False

def device_discovery():
    """
    Device discovery mode - called when CUPS wants to know about available devices.
    Always report the printer as available.
    """
    try:
        # Get the original device URI by calling the real backend
        # Use sudo for proper USB access permissions
        result = subprocess.run(["sudo", ORIGINAL_BACKEND], capture_output=True, text=True, timeout=10, errors='replace')

        if result.returncode == 0 and result.stdout.strip():
            # Parse the original backend output and modify it to show as always available
            lines = result.stdout.strip().split('\n')
            for line in lines:
                if line.startswith('direct usb://'):
                    # Modify the line to use our backend but keep the device info
                    parts = line.split()
                    if len(parts) >= 4:
                        device_uri = parts[1]
                        # Replace usb:// with always-available://
                        fake_uri = device_uri.replace('usb://', 'always-available://')
                        # Keep the rest of the information but ensure it shows as available
                        print(f"direct {fake_uri} {' '.join(parts[2:])}")
                        log_message(f"Reporting device as always available: {fake_uri}")
                else:
                    # Pass through other lines unchanged
                    print(line)
        else:
            log_message("No devices found from original backend")

    except subprocess.TimeoutExpired:
        log_message("Timeout calling original backend")
        sys.exit(CUPS_BACKEND_FAILED)
    except Exception as e:
        log_message(f"Error in device discovery: {e}")
        sys.exit(CUPS_BACKEND_FAILED)

def handle_print_job():
    """
    Print job mode - forward the job to the original backend with USB device detection and rescan.
    Now includes dynamic device discovery for printers that change URIs on power cycles.
    """
    try:
        # Log current user for debugging
        current_user = os.getuid()
        log_message(f"Backend running as UID: {current_user}")

        # Extract the device URI from environment
        device_uri = os.environ.get('DEVICE_URI', '')
        if not device_uri:
            log_message("No DEVICE_URI environment variable")
            sys.exit(CUPS_BACKEND_FAILED)

        # Convert our fake URI back to the real USB URI
        real_uri = device_uri.replace('always-available://', 'usb://')

        # Extract printer model from URI for dynamic discovery
        # Handle different URI formats (with or without serial numbers)
        uri_path = real_uri.replace('usb://', '')
        if '?' in uri_path:
            printer_model = uri_path.split('?')[0].replace('%20', ' ')
        else:
            printer_model = uri_path.replace('%20', ' ')

        log_message(f"Processing print job for: {real_uri} (model: {printer_model})")

        # Check if USB device is available, with retry logic
        device_available = check_usb_device_available(real_uri)
        actual_uri = real_uri

        if not device_available:
            log_message(f"USB device not available, attempting rescan and dynamic discovery")

            for attempt in range(USB_RESCAN_RETRIES):
                log_message(f"Discovery attempt {attempt + 1}/{USB_RESCAN_RETRIES}")

                # Trigger USB port rescan
                if rescan_usb_ports():
                    # First try the original URI
                    device_available = check_usb_device_available(real_uri)
                    if device_available:
                        log_message(f"USB device found at original URI after rescan attempt {attempt + 1}")
                        break

                    # If original URI not found, try dynamic discovery
                    discovered_uri = discover_usb_device_by_model(printer_model)
                    if discovered_uri:
                        log_message(f"USB device discovered at new URI: {discovered_uri}")
                        actual_uri = discovered_uri
                        device_available = True
                        break
                    else:
                        log_message(f"USB device still not available after rescan attempt {attempt + 1}")
                else:
                    log_message(f"USB rescan failed on attempt {attempt + 1}")

                # Wait a bit before next attempt (except on last attempt)
                if attempt < USB_RESCAN_RETRIES - 1:
                    time.sleep(1)

        if not device_available:
            log_message(f"USB device not available after all discovery attempts - job may fail")
        else:
            log_message(f"USB device available at {actual_uri} - proceeding with print job")

        # Set the actual device URI for the original backend
        env = os.environ.copy()
        env['DEVICE_URI'] = actual_uri

        # Execute the original backend with stdin/stdout redirection
        # Use sudo to ensure proper permissions for USB access
        cmd = ["sudo", "-E", ORIGINAL_BACKEND] + sys.argv[1:]
        result = subprocess.run(cmd,
                              env=env,
                              stdin=sys.stdin,
                              stdout=sys.stdout,
                              stderr=sys.stderr)

        # Return the same exit code as the original backend
        sys.exit(result.returncode)

    except Exception as e:
        log_message(f"Error forwarding print job: {e}")
        sys.exit(CUPS_BACKEND_FAILED)

def main():
    """Main entry point"""
    # Open syslog
    syslog.openlog("always-available", syslog.LOG_PID, syslog.LOG_LPR)

    if len(sys.argv) == 1:
        # Device discovery mode
        device_discovery()
    else:
        # Print job mode
        handle_print_job()

    sys.exit(CUPS_BACKEND_OK)

if __name__ == "__main__":
    main()
